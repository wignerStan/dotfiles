# Zsh Configuration (Managed by Chezmoi)
# Generated for: {{ .name }} ({{ .profile }})

# Path to Oh My Zsh installation
export ZSH="$HOME/.oh-my-zsh"

# Theme configuration
{{- if lookPath "starship" }}
# Use Starship if available
eval "$(starship init zsh)"
{{- else }}
# Fall back to Powerlevel10k
ZSH_THEME="powerlevel10k/powerlevel10k"

# Enable Powerlevel10k instant prompt
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi
{{- end }}

# Oh My Zsh plugins
plugins=(
    git
    docker
    {{- if eq .chezmoi.os "darwin" }}
    macos
    brew
    {{- end }}
    zsh-autosuggestions
    zsh-syntax-highlighting
    fzf-tab
    {{- if lookPath "kubectl" }}
    kubectl
    {{- end }}
    {{- if lookPath "terraform" }}
    terraform
    {{- end }}
)

# Load Oh My Zsh
source $ZSH/oh-my-zsh.sh

# User configuration

# Environment variables
export EDITOR='{{ if lookPath "code" }}code --wait{{ else if lookPath "vim" }}vim{{ else }}nano{{ end }}'
export VISUAL="$EDITOR"
export LANG=en_US.UTF-8

# History configuration
HISTSIZE=50000
SAVEHIST=50000
HISTFILE=~/.zsh_history
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_FIND_NO_DUPS
setopt HIST_SAVE_NO_DUPS
setopt INC_APPEND_HISTORY
setopt SHARE_HISTORY

# Path configuration
{{- if eq .chezmoi.os "darwin" }}
# macOS-specific paths
export PATH="/usr/local/bin:/usr/local/sbin:$PATH"
export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:$PATH"
{{- end }}

# User local bin
export PATH="$HOME/.local/bin:$PATH"

{{- if eq .profile "work" }}
# Work-specific paths and configurations
export PATH="$HOME/work/bin:$PATH"
{{- end }}

# Tool initializations
{{- if lookPath "zoxide" }}
# Zoxide (better cd)
eval "$(zoxide init zsh)"
{{- end }}

{{- if lookPath "fzf" }}
# FZF configuration
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh
export FZF_DEFAULT_COMMAND='{{ if lookPath "fd" }}fd --type f --hidden --follow --exclude .git{{ else }}find .{{ end }}'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_DEFAULT_OPTS='--height 40% --layout=reverse --border'
{{- end }}

{{- if lookPath "direnv" }}
# Direnv
eval "$(direnv hook zsh)"
{{- end }}

# Load shared aliases
{{- template "aliases.sh" . }}

# Custom functions
mkcd() { mkdir -p "$1" && cd "$1"; }
extract() {
    if [ -f "$1" ]; then
        case "$1" in
            *.tar.bz2)   tar xjf "$1"     ;;
            *.tar.gz)    tar xzf "$1"     ;;
            *.bz2)       bunzip2 "$1"     ;;
            *.gz)        gunzip "$1"      ;;
            *.tar)       tar xf "$1"      ;;
            *.zip)       unzip "$1"       ;;
            *.Z)         uncompress "$1"  ;;
            *)           echo "'$1' cannot be extracted" ;;
        esac
    else
        echo "'$1' is not a valid file"
    fi
}

# OS-specific configurations
{{- if eq .chezmoi.os "darwin" }}
# macOS-specific settings
alias showfiles='defaults write com.apple.finder AppleShowAllFiles YES; killall Finder /System/Library/CoreServices/Finder.app'
alias hidefiles='defaults write com.apple.finder AppleShowAllFiles NO; killall Finder /System/Library/CoreServices/Finder.app'
{{- end }}

{{- if eq .chezmoi.os "linux" }}
# Linux-specific settings
{{- if lookPath "xclip" }}
alias pbcopy='xclip -selection clipboard'
alias pbpaste='xclip -selection clipboard -o'
{{- end }}
{{- end }}

# Profile-specific configurations
{{- if eq .profile "work" }}
# Work profile settings
export WORK_ENV="production"
{{- end }}

# Local customizations (not managed by chezmoi)
[ -f ~/.zshrc_local ] && source ~/.zshrc_local

# Load Powerlevel10k config if using it
{{- if not (lookPath "starship") }}
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh
{{- end }}
