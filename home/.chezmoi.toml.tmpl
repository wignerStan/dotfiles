{{- /* Machine Configuration Logic */ -}}
{{- $ephemeral := false -}}
{{- $work := false -}}
{{- $headless := false -}}
{{- $personal := true -}}
{{- $use_china_mirrors := true -}}

{{- /* Detection: ephemeral/container environments */ -}}
{{- if or (env "CODESPACES") (env "REMOTE_CONTAINERS_IPC") (eq .chezmoi.username "root" "ubuntu") -}}
{{-   $ephemeral = true -}}
{{-   $headless = true -}}
{{- end -}}

{{- /* Detection: headless Linux (no display server, remote server) */ -}}
{{- if and (eq .chezmoi.os "linux") (not (env "DISPLAY")) (not (env "WAYLAND_DISPLAY")) -}}
{{-   $headless = true -}}
{{- end -}}

{{- /* Detection: HPC cluster (has apptainer/singularity on host) */ -}}
{{- $hpc := false -}}
{{- if or (lookPath "apptainer") (lookPath "singularity") -}}
{{-   $hpc = true -}}
{{- end -}}

{{- /* Detection: age encryption identity available */ -}}
{{- $age_identity := joinPath .chezmoi.homeDir ".config/chezmoi/age-key.txt" -}}
{{- $has_age := false -}}
{{- if stat $age_identity -}}
{{-   $has_age = true -}}
{{- end -}}

{{- $hostname := .chezmoi.hostname -}}
{{- if eq .chezmoi.os "darwin" -}}
{{-   $hostname = output "scutil" "--get" "LocalHostName" | trim -}}
{{- end -}}

{{- /* Custom Prompts — only prompt during interactive chezmoi init */ -}}
{{- $github_user := "" -}}
{{- $name := "Jacob" -}}
{{- $email := "240170694+wignerStan@users.noreply.github.com" -}}
{{- if stdinIsATTY -}}
{{-   $github_user = promptStringOnce . "github_user" "What is your GitHub username?" "" -}}
{{-   $name = promptStringOnce . "name" "What is your name?" "Jacob" -}}
{{-   $email = promptStringOnce . "email" "What is your email?" $email -}}
{{- end -}}

{{ if $has_age }}
encryption = "age"

[age]
    identity = {{ $age_identity | quote }}
    recipient = "age1s5nfmrjdljyh2hz3nary72zm5478dyrrsudgph043hmgs7c8gy4sc3ys0c"
{{ end }}

[data]
    name = {{ $name | quote }}
    email = {{ $email | quote }}
    github_user = {{ $github_user | quote }}
    hostname = {{ $hostname | quote }}
    primary_shell = "zsh"
    is_ephemeral = {{ $ephemeral }}
    is_headless = {{ $headless }}
    is_hpc = {{ $hpc }}
    is_work = {{ $work }}
    use_china_mirrors = {{ $use_china_mirrors }}
    mamba_root = {{ joinPath .chezmoi.homeDir "mamba" | quote }}
    arch = {{ .chezmoi.arch | quote }}

    # Paths for modern tools
    ghostty_config = "~/.config/ghostty/config"
    nvim_config = "~/.config/nvim"

{{- if lookPath "delta" }}
[diff]
    pager = "delta"
{{- else if lookPath "bat" }}
[diff]
    pager = "bat --style=diff"
{{- end }}
