#!/bin/bash

# ═══════════════════════════════════════════════════════════════
# Jacob's Multi-Machine Bootstrap v3
# ═══════════════════════════════════════════════════════════════

set -euo pipefail

echo "=== Starting Jacob's Dotfiles Bootstrap ==="

# 1. Mirror-aware Homebrew setup
{{- if .use_china_mirrors }}
export HOMEBREW_BREW_GIT_REMOTE="https://mirrors.ustc.edu.cn/brew.git"
export HOMEBREW_CORE_GIT_REMOTE="https://mirrors.ustc.edu.cn/homebrew-core.git"
export HOMEBREW_BOTTLE_DOMAIN="https://mirrors.ustc.edu.cn/homebrew-bottles"
export HOMEBREW_API_DOMAIN="https://mirrors.ustc.edu.cn/homebrew-bottles/api"
{{- end }}

if ! command -v brew &> /dev/null; then
    echo "Homebrew not found. Installing..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

# 2. Core packages (always installed)
echo "Installing/Updating core packages..."
core_packages=(
    zsh
    tmux
    zellij
    starship
    zoxide
    eza
    bat
    ripgrep
    fd
    neovim
    age

    # LSP & LazyVim dependencies
    npm
    rust
    go
    stylua
    luarocks
    fzf
)

# Install packages individually so one missing doesn't block the rest
for pkg in "${core_packages[@]}"; do
    brew install "$pkg" 2>/dev/null || echo "Warning: failed to install $pkg, skipping"
done

# 3. Desktop-only packages
{{- if not .is_headless }}
echo "Installing desktop-only packages..."
desktop_packages=(
    fish
    nushell
    mihomo
    ghostty
    kubecolor
)

brew install "${desktop_packages[@]}"
{{- end }}

echo "=== Bootstrap Complete ==="
