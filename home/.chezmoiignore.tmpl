{{- if .is_headless }}
# GUI/desktop-only tools — skip on headless servers
.config/ghostty/
.config/mihomo/
.config/sing-box/
{{- end }}

{{- if .is_hpc }}
# Workstation-only tools — skip on HPC clusters
.config/ghostty/
.config/mihomo/
.config/nushell/
.config/fish/
.config/zellij/
.config/starship.toml
.config/yazi/
.oh-my-zsh/
.iterm2_shell_integration.zsh

# Shell tools — managed by deploy scripts, not chezmoi
container-data/

# Workstation zsh configs — HPC uses container-data/zsh/ instead
.zshenv
.zshrc
.zprofile

# Workstation scripts — require Homebrew/GitHub access
bootstrap.sh
reload-configs.sh
install-yazi-plugins.sh
{{- else }}
# HPC container configs — skip on workstation
container-data/
{{- end }}

{{- if eq .chezmoi.os "darwin" }}
# Byobu is Linux-only (depends on /usr/share/byobu/, /usr/lib/byobu/)
.byobu/
{{- end }}
