return {
  {
    "LazyVim/LazyVim",
    opts = function(_, opts)
{{- if .is_headless }}
      -- OSC52 clipboard for headless/SSH sessions
      local osc52 = require("vim.ui.clipboard.osc52")
      local cache_dir = vim.fn.stdpath("cache") .. "/osc52"
      vim.fn.mkdir(cache_dir, "p")
      local cache_file = cache_dir .. "/clipboard"

      vim.g.clipboard = {
        name = "OSC 52 (cached)",
        copy = {
          ["+"] = function(lines)
            osc52.copy("+")(lines)
            local f = io.open(cache_file, "w")
            if f then
              f:write(table.concat(lines, "\n"))
              f:close()
            end
          end,
          ["*"] = function(lines)
            osc52.copy("*")(lines)
            local f = io.open(cache_file, "w")
            if f then
              f:write(table.concat(lines, "\n"))
              f:close()
            end
          end,
        },
        paste = {
          ["+"] = function()
            local f = io.open(cache_file, "r")
            if f then
              local content = f:read("*a")
              f:close()
              content = content:gsub("\n$", "")
              if #content > 0 then
                return vim.split(content, "\n")
              end
            end
            return {}
          end,
          ["*"] = function()
            local f = io.open(cache_file, "r")
            if f then
              local content = f:read("*a")
              f:close()
              content = content:gsub("\n$", "")
              if #content > 0 then
                return vim.split(content, "\n")
              end
            end
            return {}
          end,
        },
        cache_enabled = true,
      }
{{- end }}

      -- Always ensure clipboard is set; LazyVim resets it on VeryLazy
      vim.opt.clipboard = "unnamedplus"
      vim.api.nvim_create_autocmd("User", {
        pattern = "VeryLazy",
        once = true,
        callback = function()
          vim.defer_fn(function()
            vim.opt.clipboard = "unnamedplus"
          end, 100)
        end,
      })
    end,
  },
}
