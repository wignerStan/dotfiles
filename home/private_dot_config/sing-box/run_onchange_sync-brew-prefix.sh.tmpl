#!/bin/bash
# sync sing-box config: render template -> inject subscription -> validate -> deploy
set -euo pipefail

{{- if lookPath "brew" }}
BREW_ETC="$(brew --prefix)/etc/sing-box"
{{- else }}
BREW_ETC="/opt/homebrew/etc/sing-box"
{{- end }}
SRC="{{ .chezmoi.homeDir }}/.config/sing-box"
DST="$BREW_ETC"

if [ ! -d "$DST" ]; then
    echo "sing-box: $DST does not exist, skipping sync"
    exit 0
fi

# sync base template configs first
for f in config-android.json inject-sub.py update-rulesets.sh; do
    if [ -f "$SRC/$f" ]; then
        cp "$SRC/$f" "$DST/$f"
    fi
done

# macOS config: render template -> inject subscription -> deploy
if [ -f "$SRC/inject-sub.py" ]; then
    SUB_URL="{{ .singbox_sub_url | default "" }}"
    if [ -n "$SUB_URL" ]; then
        python3 "$SRC/inject-sub.py" -s "$SUB_URL" -o "$DST/config.json" < "$SRC/config.json"
        echo "sing-box: injected subscription -> $DST/config.json"
    else
        cp "$SRC/config.json" "$DST/config.json"
        echo "sing-box: synced config.json -> $DST/ (no sub url)"
    fi
fi

# validate
if command -v sing-box &>/dev/null && [ -f "$DST/config.json" ]; then
    if sing-box check -c "$DST/config.json" 2>&1; then
        echo "sing-box: config valid"
    else
        echo "sing-box: WARNING config validation failed" >&2
        exit 1
    fi
fi
