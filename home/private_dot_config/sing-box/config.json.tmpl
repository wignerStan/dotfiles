          "xn--ngstr-lra8j.com",
          "linux.do"
        ],
        "server": "dns-remote"
      },
      {
        "rule_set": "geosite-cn",
        "server": "dns-domestic"
      },
      {
        "domain_suffix": ".ts.net",
        "server": "dns-tailscale"
      },
      {
        "domain_suffix": [
           "linuxdo.org",
           "sharedchat.cc"
        ],
        "server": "dns-domestic"
      },
      {
        "domain": "engage.cloudflareclient.com",
        "server": "dns-remote"
      },
      {
        "query_type": [
          "A",
          "AAAA"
        ],
        "server": "dns-fakeip"
      }
    ],
    "final": "dns-remote",
    "reverse_mapping": true,
    "strategy": "ipv4_only",
    "independent_cache": true
  },
  "endpoints": [
    {
      "type": "tailscale",
      "tag": "ts-ep",
      "state_directory": "{{ $singbox_dir }}/tailscale-state",
      "accept_routes": true,
      "system_interface": true,
      "system_interface_name": "utun101"
    },
    {
      "type": "wireguard",
      "tag": "warp-ep",
      "system": false,
      "mtu": 1280,
      "address": [
        "172.16.0.2/32",
        "{{ .singbox_warp_ipv6 }}/128"
      ],
      "private_key": {{ .singbox_warp_private_key | quote }},
      "peers": [
        {
          "address": "engage.cloudflareclient.com",
          "port": 2408,
          "public_key": "bmXOC+F1FxEMF9dyiK2H5/1SUtzH0JuVo51h2wPfgyo=",
          "allowed_ips": ["0.0.0.0/0", "::/0"],
          "reserved": [{{ .singbox_warp_reserved_0 }}, {{ .singbox_warp_reserved_1 }}, {{ .singbox_warp_reserved_2 }}],
          "persistent_keepalive_interval": 25
        }
      ],
      "detour": "proxy"
    }
  ],
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "interface_name": "utun100",
      "mtu": 1500,
      "address": [
        "172.19.0.1/30",
        "fdfe:dcba:9876::1/126"
      ],
      "auto_route": true,
      "route_exclude_address": [
        "0.0.0.0/8",
        "10.0.0.0/8",
        "100.64.0.0/10",
        "100.100.0.0/16",
        "127.0.0.0/8",
        "169.254.0.0/16",
        "172.16.0.0/12",
        "192.0.0.0/24",
        "192.0.2.0/24",
        "192.88.99.0/24",
        "192.168.0.0/16",
        "203.0.113.0/24",
        "224.0.0.0/4",
        "240.0.0.0/4",
        "255.255.255.255/32",
        "::1/128",
        "64:ff9b::/96",
        "fc00::/7",
        "fe80::/10",
        "ff00::/8"
      ],
      "route_exclude_address_set": [],
      "exclude_interface": "utun4",
      "stack": "gvisor"
    },
    {
      "type": "mixed",
      "tag": "mixed-in",
      "listen": "0.0.0.0",
      "listen_port": 7897,
      "bind_interface": "utun101"
    },
    {
      "type": "mixed",
      "tag": "mixed-in-local",
      "listen": "127.0.0.1",
      "listen_port": 7899
    },
    {
      "type": "socks",
      "tag": "socks-residential-in",
      "listen": "127.0.0.1",
      "listen_port": 7898
    }
  ],
  "outbounds": [
    {
      "type": "selector",
      "tag": "proxy",
      "outbounds": ["auto-proxy", "VLESS", "VLESS-CDN"],
      "default": "VLESS"
    },
    {
      "type": "urltest",
      "tag": "auto-proxy",
      "outbounds": ["VLESS", "VLESS-CDN"],
      "url": "https://www.gstatic.com/generate_204",
      "interval": "3m",
      "tolerance": 50
    },
    {
      "type": "selector",
      "tag": "ai-chain",
      "outbounds": ["VLESS", "VLESS-CDN", "warp-ep", "residential"],
      "default": "warp-ep"
    },
    {
      "type": "vless",
      "tag": "VLESS",
      "server": {{ .singbox_server | quote }},
      "server_port": 443,
      "uuid": {{ .singbox_uuid | quote }},
      "flow": "xtls-rprx-vision",
      "tls": {
        "enabled": true,
        "server_name": "www.cisco.com",
        "utls": {
          "enabled": true,
          "fingerprint": "chrome"
        },
        "reality": {
          "enabled": true,
          "public_key": {{ .singbox_public_key | quote }}
        }
      }
    },
    {
      "type": "vless",
      "tag": "VLESS-CDN",
      "server": {{ .singbox_cdn_host | quote }},
      "server_port": {{ .singbox_cdn_port }},
      "uuid": {{ .singbox_uuid | quote }},
      "tls": {
        "enabled": true,
        "server_name": {{ .singbox_cdn_host | quote }},
        "utls": {
          "enabled": true,
          "fingerprint": "chrome"
        }
      },
      "transport": {
        "type": "ws",
        "path": {{ .singbox_cdn_path | quote }}
      }
    },
    {
      "type": "vless",
      "tag": "residential",
      "server": {{ .singbox_server | quote }},
      "server_port": 443,
      "uuid": {{ .singbox_residential_uuid | quote }},
      "flow": "xtls-rprx-vision",
      "tls": {
        "enabled": true,
        "server_name": "www.cisco.com",
        "utls": {
          "enabled": true,
          "fingerprint": "chrome"
        },
        "reality": {
          "enabled": true,
          "public_key": {{ .singbox_public_key | quote }},
          "short_id": {{ .singbox_residential_short_id | quote }}
        }
      }
    },
    {
      "type": "direct",
      "tag": "direct"
    }
  ],
  "route": {
    "rules": [
      {
        "action": "sniff"
      },
      {
        "inbound": "socks-residential-in",
        "outbound": "residential"
      },
      {
        "protocol": "dns",
        "action": "hijack-dns"
      },
      {
        "ip_cidr": [
          "100.64.0.0/10",
          "fd7a:115c:a1e0::/48"
        ],
