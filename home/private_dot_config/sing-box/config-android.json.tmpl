        "server": "dns-fakeip"
      }
    ],
    "final": "dns-remote",
    "reverse_mapping": true,
    "strategy": "ipv4_only",
    "independent_cache": true
  },
  "endpoints": [
    {
      "type": "tailscale",
      "tag": "ts-ep",
      "state_directory": "tailscale-state",
      "accept_routes": true,
      "exit_node": "100.73.12.63",
      "exit_node_allow_lan_access": true
    }
  ],
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "address": [
        "172.19.0.1/30",
        "fdfe:dcba:9876::1/126"
      ],
      "auto_route": true,
      "stack": "gvisor"
    }
  ],
  "outbounds": [
    {
      "type": "selector",
      "tag": "proxy",
      "outbounds": ["auto-proxy", "VLESS", "residential", "ts-socks", "ts-route", "ts-ep"],
      "default": "VLESS"
    },
    {
      "type": "urltest",
      "tag": "auto-proxy",
      "outbounds": ["VLESS", "residential"],
      "url": "https://www.gstatic.com/generate_204",
      "interval": "3m",
      "tolerance": 50
    },
    {
      "type": "vless",
      "tag": "VLESS",
      "server": {{ .singbox_server | quote }},
      "server_port": 443,
      "uuid": {{ .singbox_android_uuid | quote }},
      "flow": "xtls-rprx-vision",
      "tls": {
        "enabled": true,
        "server_name": "www.cisco.com",
        "utls": {
          "enabled": true,
          "fingerprint": "chrome"
        },
        "reality": {
          "enabled": true,
          "public_key": {{ .singbox_public_key | quote }}
        }
      }
    },
    {
      "type": "vless",
      "tag": "residential",
      "server": {{ .singbox_server | quote }},
      "server_port": 443,
      "uuid": {{ .singbox_residential_uuid | quote }},
      "flow": "xtls-rprx-vision",
      "tls": {
        "enabled": true,
        "server_name": "www.cisco.com",
        "utls": {
          "enabled": true,
          "fingerprint": "chrome"
        },
        "reality": {
          "enabled": true,
          "public_key": {{ .singbox_public_key | quote }},
          "short_id": {{ .singbox_residential_short_id | quote }}
        }
      }
    },
    {
      "type": "socks",
      "tag": "ts-socks",
      "server": "100.73.12.63",
      "server_port": 10808
    },
    {
      "type": "socks",
      "tag": "ts-route",
      "server": "100.73.12.63",
      "server_port": 10809
    },
    {
      "type": "direct",
      "tag": "direct"
    },
    {
      "type": "block",
      "tag": "block"
    }
