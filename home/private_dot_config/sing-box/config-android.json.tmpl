      },
      {
        "type": "udp",
        "tag": "dns-ustc",
        "server": "202.38.64.18",
        "server_port": 53
      },
      {
        "type": "tailscale",
        "tag": "dns-tailscale",
        "endpoint": "ts-ep",
        "accept_default_resolvers": true
      },
      {
        "type": "https",
        "tag": "dns-remote",
        "server": "1.1.1.1",
