# Ghostty Configuration
# Based on: https://linux.do/t/topic/1301315

# ========== Shell Integration ==========
shell-integration = fish
shell-integration-features = no-ssh-terminfo,ssh-env,no-cursor,title
command = /opt/homebrew/bin/fish

# ========== Theme ==========
theme = iTerm2 Solarized Dark

# ========== Font ==========
font-family = "Maple Mono NF CN Light"
font-size = 14
adjust-cell-height = 25%
# calt: ligatures | cv01: no gaps | cv03: alt @ | ss01: split = | ss02: split <> | ss03: force >> ligature
font-feature = calt, cv01, cv03, ss01, ss02, ss03
font-thicken = false

# ========== Visuals ==========
background-opacity = 0.97
window-padding-x = 8
window-padding-y = 8
macos-window-shadow = true
mouse-hide-while-typing = true

# ========== Cursor ==========
cursor-style = block
cursor-color = #ff9e64
cursor-text = #002b36
cursor-style-blink = true

# ========== Window ==========
window-decoration = true
macos-titlebar-style = tabs
window-save-state = always

# ========== Scrollback ==========
# 200MB for Claude Code long sessions
scrollback-limit = 200000000

# ========== Keybinds ==========
# Quick Terminal (Slide Feature)
keybind = global:super+backquote=toggle_quick_terminal

# Tab / Window
keybind = super+t=new_tab
keybind = super+n=new_window
keybind = super+shift+w=close_surface
keybind = super+w=close_tab
keybind = super+shift+left=previous_tab
keybind = super+shift+right=next_tab

# Splits
keybind = super+d=new_split:right
keybind = super+shift+d=new_split:down

# Enter mappings
keybind = shift+enter=text:\x1b\r
keybind = ctrl+enter=text:\\r

# Reset stuck/frozen terminal
keybind = super+shift+r=reset
