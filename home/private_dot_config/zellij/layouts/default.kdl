// Layout file for zjstatus status bar
// This replaces the default status-bar plugin with zjstatus
// which provides system monitoring widgets (CPU, memory, network, datetime)

layout {
    default_tab_template {
        children
        pane size=1 borderless=true {
            plugin location="file:/home/jacob/.config/zellij/plugins/zjstatus.wasm" {
                // Left: mode indicator + session name + tabs
                format_left   "#[bg=#002b36] {mode} #[fg=#839496,bg=#002b36] {session}"
                format_center "{tabs}"
                // Right: system monitors + datetime (replicating tmux-powerkit)
                format_right  "{command_cpu}#[fg=#586e75] │ #[fg=#839496]{command_memory}#[fg=#586e75] │ #[fg=#839496]{command_netspeed}#[fg=#586e75] │ #[fg=#839496]{command_datetime}"
                format_space  ""

                // Mode indicators (solarized colors)
                mode_normal        "#[bg=#859900,fg=#002b36] NORMAL "
                mode_pane          "#[bg=#268bd2,fg=#002b36] PANE "
                mode_tab           "#[bg=#268bd2,fg=#002b36] TAB "
                mode_resize        "#[bg=#268bd2,fg=#002b36] RESIZE "
                mode_move          "#[bg=#268bd2,fg=#002b36] MOVE "
                mode_scroll        "#[bg=#268bd2,fg=#002b36] SCROLL "
                mode_search        "#[bg=#268bd2,fg=#002b36] SEARCH "
                mode_session       "#[bg=#268bd2,fg=#002b36] SESSION "
                mode_tmux          "#[bg=#dc322f,fg=#002b36] TMUX "
                mode_locked        "#[bg=#586e75,fg=#002b36] LOCKED "
                mode_entersearch   "#[bg=#268bd2,fg=#002b36] SEARCH "

                // Tab formatting
                tab_normal   "#[fg=#586e75,bg=#002b36] {index} {name} {fullscreen_indicator}{sync_indicator} "
                tab_active   "#[fg=#93a1a1,bg=#002b36,bold] {index} {name} {fullscreen_indicator}{sync_indicator} "
                tab_fullscreen_indicator " Z "
                tab_sync_indicator       " S "

                // Separator between tabs
                tab_separator ""

                // CPU widget
                command_cpu_command     "awk '/^cpu / {u=$2-$9; n=$2+$4+$5; printf \"%.0f\", u*100/n}' /proc/stat"
                command_cpu_format      "#[fg=#859900,bg=#002b36] CPU {stdout}% "
                command_cpu_interval    10
                command_cpu_rendermode  "static"

                // Memory widget
                command_memory_command     "free | awk '/Mem:/ {printf \"%d/%dMB\", $3/1024, $2/1024}'"
                command_memory_format      "#[fg=#268bd2,bg=#002b36] MEM {stdout} "
                command_memory_interval    10
                command_memory_rendermode  "static"

                // Network speed widget
                command_netspeed_command     "awk 'NR>2 {rx=$2; tx=$10} END {printf \"%.0fK/%.0fK\", rx/1024, tx/1024}' /proc/net/dev"
                command_netspeed_format      "#[fg=#6c71c4,bg=#002b36] NET {stdout} "
                command_netspeed_interval    5
                command_netspeed_rendermode  "static"

                // DateTime widget
                command_datetime_command     "date '+%a %b-%d %H:%M'"
                command_datetime_format      "#[fg=#93a1a1,bg=#002b36] {stdout} "
                command_datetime_interval    10
                command_datetime_rendermode  "static"

                // Styling
                border_enabled  "false"
                border_char     "─"
                border_format   "#[fg=#6C7086]{char}"
                border_position "top"
                hide_frame_for_single_pane "true"
            }
        }
    }
}
