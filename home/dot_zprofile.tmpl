# ═══════════════════════════════════════════════════════════════
# .zprofile — Login shells only (runs once per login session)
# Heavy subshell initializations moved here from .zshenv to avoid
# ~60ms fork tax on every non-interactive zsh invocation.
# ═══════════════════════════════════════════════════════════════

# ── Homebrew (static — PATH already set in .zshenv, just export vars)
{{- if eq .chezmoi.os "darwin" }}
export HOMEBREW_CELLAR="/opt/homebrew/Cellar"
export HOMEBREW_REPOSITORY="/opt/homebrew"
{{- else if eq .chezmoi.os "linux" }}
if [[ -d "/home/linuxbrew/.linuxbrew" ]]; then
    export HOMEBREW_CELLAR="/home/linuxbrew/.linuxbrew/Cellar"
    export HOMEBREW_REPOSITORY="/home/linuxbrew/.linuxbrew/Homebrew"
fi
{{- end }}

# ── Mamba shell hook (MAMBA_EXE/MAMBA_ROOT_PREFIX/PATH set in .zshenv) ───
{{- if lookPath "micromamba" }}
__mamba_setup="$("$MAMBA_EXE" shell hook --shell zsh --root-prefix "$MAMBA_ROOT_PREFIX" 2> /dev/null)"
if [ $? -eq 0 ]; then
    eval "$__mamba_setup"
else
    alias mamba="$MAMBA_EXE"
fi
unset __mamba_setup
{{- end }}
