# =============================================================================
# Tmux configuration — socket-separated router
# Default socket: delegates to byobu config (single source of truth)
# CC socket:      iTerm2 -CC status bar (no plugins)
# =============================================================================
{{- if .is_hpc }}

# HPC — source byobu config (bash shell, managed by chezmoi)
source-file ~/.byobu/.tmux.conf

{{- else }}

# Default socket: source byobu config
%if "#{==:#{socket_path},/tmp/tmux-1000/default}"
source-file ~/.byobu/.tmux.conf
%endif

# =============================================================================
# CC socket only: rich status bar via #() shell commands
# No TPM/plugins — pure shell commands that iTerm2 -CC can read from
# status-left/status-right (status-format is NOT supported by -CC).
# =============================================================================
%if "#{==:#{socket_path},/tmp/tmux-1000/cc}"

# iTerm2 -CC: incompatible with aggressive-resize and Nerd Font glyphs.
set -g aggressive-resize off

# Hide tmux window list — iTerm2 native tabs handle window navigation.
set -g window-status-format ""
set -g window-status-current-format ""

# Status left — hostname + session
set -g status-left-length 50
set -g status-left "#[fg=green,bold]#H #[fg=cyan]‹#S› "

# Status right — server vitals via helper script (colored blocks)
set -g status-right-length 200
set -g status-right "#(/home/jacob/.local/bin/tmux-cc-status) "

%endif
{{- end }}
