# ═══════════════════════════════════════════════════════════════
# .tmux.conf - Poweruser Multiplexer Config
# ═══════════════════════════════════════════════════════════════

# ── Shell (non-login for agent compatibility) ──
# default-command bypasses tmux's login-shell mechanism.
# Result: .zshenv sources, .zprofile skipped.
# .zshrc human-friendly stuff (fastfetch, starship, fzf, aliases)
# is guarded by [[ -z "$TMUX" ]] so it only runs outside tmux.
{{- if eq .chezmoi.os "darwin" }}
run-shell 'tmux set-option -g default-command "$(brew --prefix)/bin/zsh"'
run-shell 'tmux set-option -g default-shell "$(brew --prefix)/bin/zsh"'
{{- else }}
run-shell 'tmux set-option -g default-command "/bin/zsh"'
run-shell 'tmux set-option -g default-shell "/bin/zsh"'
{{- end }}

# Core settings
set -g prefix F12
bind F12 send-prefix
set-window-option -g xterm-keys on
set -s escape-time 50
set -g mouse on
set -g allow-passthrough on
set -s set-clipboard on

# Copy mode — vi-style
setw -g mode-keys vi
bind Escape copy-mode
unbind p
bind p paste-buffer
bind-key -T copy-mode-vi v send-keys -X begin-selection
bind-key -T copy-mode-vi y send-keys -X copy-pipe-and-cancel "base64 | tr -d '\\n' | xargs -0 printf '\\033]52;c;%s\\033\\\\'"
bind-key -T copy-mode-vi MouseDragEnd1Pane send-keys -X copy-pipe-and-cancel "base64 | tr -d '\\n' | xargs -0 printf '\\033]52;c;%s\\033\\\\'"
bind-key -T copy-mode-vi DoubleClick1Pane  select-pane \; send-keys -X select-word \; run-shell -d 0.3 \; send-keys -X copy-pipe-and-cancel "base64 | tr -d '\\n' | xargs -0 printf '\\033]52;c;%s\\033\\\\'"
bind-key -T copy-mode-vi TripleClick1Pane  select-pane \; send-keys -X select-line \; run-shell -d 0.3 \; send-keys -X copy-pipe-and-cancel "base64 | tr -d '\\n' | xargs -0 printf '\\033]52;c;%s\\033\\\\'"
bind-key -T copy-mode-vi Enter             send-keys -X copy-pipe-and-cancel "base64 | tr -d '\\n' | xargs -0 printf '\\033]52;c;%s\\033\\\\'"
bind-key -T copy-mode-vi C-j               send-keys -X copy-pipe-and-cancel "base64 | tr -d '\\n' | xargs -0 printf '\\033]52;c;%s\\033\\\\'"

# Splits (intuitive | and -)
bind | split-window -h -c "#{pane_current_path}"
bind - split-window -v -c "#{pane_current_path}"

# Synchronize panes toggle
bind y set-window-option synchronize-panes

# ── Pane navigation (Vim style) ──
bind h select-pane -L
bind j select-pane -D
bind k select-pane -U
bind l select-pane -R

# ── Status bar ──
set -g status-bg black
set -g status-fg white
set -g status-interval 5
set -g status-left-length 30
set -g status-left '#[fg=green](#S) #(whoami)'
set -g status-right '#[fg=yellow]#(cut -d " " -f 1-3 /proc/loadavg) #[fg=white]%H:%M'
